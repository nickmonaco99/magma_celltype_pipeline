# =============================================================================
# magma_celltype_pipeline — .gitignore
# =============================================================================
# Principle: track CODE and SMALL RESULTS. Exclude raw data (re-downloadable
# via bootstrap.sh) and intermediate MAGMA outputs (re-generated each run).
# =============================================================================

# ---- Reference data (downloaded via bootstrap.sh) ----
# 1000 Genomes EUR LD reference panel (~3.5 GB)
auxfiles/g1000_eur.bed
auxfiles/g1000_eur.bim
auxfiles/g1000_eur.fam
auxfiles/g1000_eur.synonyms
# Keep the README and any .md notes describing aux files
!auxfiles/README*
!auxfiles/*.md
# NCBI37.3.gene.loc symlink stays tracked (tiny target file)
# but its target (the actual file in duncan_repo/) is fine

# ---- MAGMA binary (downloaded via bootstrap.sh) ----
magma_binary/magma
magma_binary/*.zip
# Keep any README in the dir
!magma_binary/README*

# ---- Siletti specificity matrix (from team Google Drive, ~148 MB) ----
gene-level/*.txt
gene-level/*.tsv
# Keep documentation
!gene-level/README*
!gene-level/*.md

# ---- GWAS sumstats (downloaded via bootstrap, CC BY-NC-SA licensed) ----
# These are too big AND have non-commercial license restrictions
gwas_sumstats/**/*.gz
gwas_sumstats/**/*.tsv
gwas_sumstats/**/*.txt
gwas_sumstats/**/*.vcf
gwas_sumstats/**/*.bgz
gwas_sumstats/**/*.zip
# Keep the READMEs that describe each GWAS source
!gwas_sumstats/**/README*
!gwas_sumstats/**/*.md

# ---- MAGMA intermediate outputs (re-generated on every run) ----
# Track the small final outputs (genes.out, gsa.out) ONLY via snapshots/.
# Don't track the working results/<gwas>/ directories.
results/*/
!results/snapshots/

# Within snapshots/, large intermediate files we don't want even there:
results/snapshots/**/*.no_heading
results/snapshots/**/*.genes.annot
results/snapshots/**/*.genes.raw
results/snapshots/**/snploc_*

# ---- Scratch and figures from working runs ----
scratch/
figures/*.png
figures/*.pdf
figures/*.svg
# But keep README
!figures/README*

# ---- Python / standard ----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# ---- Jupyter ----
*.ipynb_checkpoints

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
._*

# ---- Linux ----
*~
.directory
.Trash-*

# ---- Docker ----
.docker/

# ---- Logs / temp ----
*.log
!run.log
!*.step2.log
!*.gsa.log
/tmp/
*.tmp
*.bak

# ---- Local environment ----
.env
.env.local
venv/
.venv/
env/
